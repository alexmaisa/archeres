# Archeres Production Environment Variables Template
# Copy this file to '.env' and fill in your secure credentials before running docker compose

# Go Backend Configurations
PORT=8080
DATABASE_PATH=/app/data/archeres.db

# High-entropy JWT Signing Secret Key (Mandatory for Production)
# Generate a secure random string (e.g. using 'openssl rand -hex 32')
JWT_SECRET=replace_this_with_a_secure_random_hex_string_32_characters
